---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - APV Valence">

  <!-- En-tete simple -->
  <section class="px-6 pt-16 pb-10 md:pt-24 md:pb-12 text-center">
    <div class="max-w-2xl mx-auto">
      <p class="page-subtitle">Nous &eacute;crire</p>
      <h1 class="page-title">Contact</h1>
      <p class="body-text">
        Une question ou l&rsquo;envie de pousser la porte un jeudi ? Voici comment nous joindre.
      </p>
    </div>
  </section>

  <!-- Contenu : infos + illustration -->
  <section class="px-6 pb-14">
    <div class="max-w-3xl mx-auto grid md:grid-cols-[1fr_auto] gap-10 items-center">
      
      <!-- Carte infos -->
      <div class="stamp-card postal-frame paper p-8 space-y-6">
        <div>
          <p class="label">Adresse</p>
          <p class="text-stone-800 leading-relaxed">
            Maison de la Vie Associative<br />
            74 route de Mont&eacute;lier<br />
            26000 Valence
          </p>
        </div>
        <div>
          <p class="label">Horaires</p>
          <p class="text-stone-800">Tous les jeudis apr&egrave;s-midi</p>
        </div>
        <div>
          <p class="label">Email</p>
          <a href="mailto:contact@assophil-valence.net" class="text-primary-700 hover:text-primary-900 transition font-medium">
            contact@assophil-valence.net
          </a>
        </div>
      </div>

      <!-- Boite aux lettres -->
      <div class="flex justify-center">
        <svg width="100" height="100" viewBox="0 0 88 88" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <ellipse cx="44" cy="80" rx="22" ry="4" fill="#1e3a5f" opacity="0.08"/>
          <rect x="40" y="62" width="8" height="16" rx="1" fill="#1e3a5f"/>
          <rect x="14" y="28" width="60" height="36" rx="4" fill="#f7f3ea" stroke="#1e3a5f" stroke-width="2"/>
          <rect x="14" y="28" width="60" height="10" rx="4" fill="#1e3a5f"/>
          <rect x="14" y="34" width="60" height="4" fill="#1e3a5f"/>
          <rect x="28" y="42" width="32" height="4" rx="2" fill="#1e3a5f" opacity="0.85"/>
          <rect x="52" y="48" width="14" height="12" rx="1.5" fill="#efe9dc" stroke="#1e3a5f" stroke-width="1.5"/>
          <circle cx="62" cy="54" r="1.5" fill="#a67443"/>
          <path d="M20 28 L20 14 L34 18 L20 22" fill="#a67443" stroke="#1e3a5f" stroke-width="1"/>
        </svg>
      </div>

    </div>
  </section>

  <!-- Carte -->
  <section class="px-6 pb-20">
    <div class="max-w-3xl mx-auto">
      <p class="label mb-3 text-center">Nous trouver</p>
      <div class="overflow-hidden border border-stone-300 shadow-sm stamp-card">
        <iframe
          title="Carte - Maison de la Vie Associative Valence"
          src="https://maps.google.com/maps?q=74%20route%20de%20Mont%C3%A9lier%2026000%20Valence&t=&z=15&ie=UTF8&iwloc=&output=embed"
          class="w-full h-72 border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

</Layout>