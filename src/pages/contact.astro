---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - APV Valence">

  <section class="px-6 pt-16 pb-10 md:pt-24 md:pb-12 text-center">
    <div class="max-w-2xl mx-auto">
      <p class="page-subtitle">Nous &eacute;crire</p>
      <h1 class="page-title">Contact</h1>
      <p class="body-text">
        Une question ou l&rsquo;envie de pousser la porte un jeudi ? Voici comment nous joindre.
      </p>
    </div>
  </section>

  <section class="px-6 pb-14">
    <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-10 items-start">
      
      <!-- Infos -->
      <div class="stamp-card postal-frame paper p-8 space-y-6">
        <div>
          <p class="label">Adresse</p>
          <p class="text-stone-800 leading-relaxed">
            Maison de la Vie Associative<br />
            74 route de Mont&eacute;lier<br />
            26000 Valence
          </p>
        </div>
        <div>
          <p class="label">Horaires</p>
          <p class="text-stone-800">Tous les jeudis apr&egrave;s-midi</p>
        </div>
        <div>
          <p class="label">Email</p>
          <a href="mailto:contact@assophil-valence.net" class="text-primary-700 hover:text-primary-900 transition font-medium">
            contact@assophil-valence.net
          </a>
        </div>
      </div>

      <!-- Formulaire Netlify -->
      <div class="stamp-card postal-frame paper p-8">
        <p class="label mb-4">Formulaire de contact</p>
        <form name="contact" method="POST" action="/merci" data-netlify="true" netlify-honeypot="bot-field" class="space-y-4">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden">
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </p>
          <div>
            <label for="name" class="block text-[13px] text-stone-600 mb-1">Nom</label>
            <input type="text" id="name" name="name" required
              class="w-full border border-stone-300 rounded-lg px-3 py-2 text-[14px] focus:outline-none focus:border-stone-500" />
          </div>
          <div>
            <label for="email" class="block text-[13px] text-stone-600 mb-1">Email</label>
            <input type="email" id="email" name="email" required
              class="w-full border border-stone-300 rounded-lg px-3 py-2 text-[14px] focus:outline-none focus:border-stone-500" />
          </div>
          <div>
            <label for="message" class="block text-[13px] text-stone-600 mb-1">Message</label>
            <textarea id="message" name="message" rows="4" required
              class="w-full border border-stone-300 rounded-lg px-3 py-2 text-[14px] focus:outline-none focus:border-stone-500"></textarea>
          </div>
          <button type="submit"
            class="w-full border border-stone-400 bg-[#faf7f2] text-stone-800 px-6 py-3 rounded-lg text-[13px] font-medium hover:bg-white transition">
            Envoyer
          </button>
        </form>
      </div>

    </div>
  </section>

  <section class="px-6 pb-20">
    <div class="max-w-3xl mx-auto">
      <p class="label mb-3 text-center">Nous trouver</p>
      <div class="overflow-hidden border border-stone-300 shadow-sm stamp-card">
        <iframe
          title="Carte - Maison de la Vie Associative Valence"
          src="https://maps.google.com/maps?q=74%20route%20de%20Mont%C3%A9lier%2026000%20Valence&t=&z=15&ie=UTF8&iwloc=&output=embed"
          class="w-full h-72 border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

</Layout>