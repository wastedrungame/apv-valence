---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Message envoyé - APV Valence">

  <section class="px-6 pt-24 pb-32 text-center">
    <div class="max-w-xl mx-auto stamp-card postal-frame paper p-10 md:p-14">
      <p class="page-subtitle mb-4">Contact</p>
      <h1 class="font-serif text-2xl md:text-3xl font-semibold text-stone-900 mb-4">
        Message envoyé
      </h1>
      <p class="body-text mb-8">
        Merci pour votre message. Nous vous répondrons dès que possible.
      </p>
      <a href="/" class="inline-flex items-center justify-center border border-stone-400 bg-[#faf7f2] text-stone-800 px-8 py-3 rounded-lg text-[13px] font-medium hover:bg-white transition">
        Retour à l’accueil
      </a>
    </div>
  </section>

</Layout>