---
---

<header class="border-b border-stone-200/60 bg-[#faf7f2] sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/apv-valence/" class="flex items-center gap-3">
      <img src="/apv-valence/logo-apv.png" alt="APV" class="h-10 w-auto object-contain" />
      <span class="font-serif font-semibold text-stone-900 text-[15px]">APV Valence</span>
    </a>
    <nav class="hidden md:flex items-center gap-5 text-[13px] font-bold text-stone-700">
      <a href="/apv-valence/">Accueil</a>
      <a href="/apv-valence/association">L&apos;Association</a>
      <a href="/apv-valence/actualites">Actualit&eacute;s</a>
      <a href="/apv-valence/agenda">Agenda</a>
      <a href="/apv-valence/galerie">Galerie</a>
      <a href="/apv-valence/adhesion">Adh&eacute;sion</a>
      <a href="/apv-valence/contact">Contact</a>
    </nav>
    <button id="menu-btn" type="button" class="md:hidden p-2 text-stone-600" aria-label="Menu">Menu</button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden border-t border-stone-200 bg-[#faf7f2] px-6 py-4">
    <nav class="flex flex-col gap-3 text-[14px] font-bold text-stone-700">
      <a href="/apv-valence/">Accueil</a>
      <a href="/apv-valence/association">L&apos;Association</a>
      <a href="/apv-valence/actualites">Actualit&eacute;s</a>
      <a href="/apv-valence/agenda">Agenda</a>
      <a href="/apv-valence/galerie">Galerie</a>
      <a href="/apv-valence/adhesion">Adh&eacute;sion</a>
      <a href="/apv-valence/contact">Contact</a>
    </nav>
  </div>
</header>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var btn = document.getElementById('menu-btn');
    var menu = document.getElementById('mobile-menu');
    if (btn && menu) btn.addEventListener('click', function () { menu.classList.toggle('hidden'); });
  });
</script>